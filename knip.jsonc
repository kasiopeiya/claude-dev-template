{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["eslint-rules/*.test.mjs"],
      "project": ["eslint-rules/**/*.mjs"]
    },
    "infra": {
      "entry": [
        "bin/app.ts",
        // Lambda ハンドラは CDK が実行時に文字列パス(entry: path.join(...))で参照するため、
        // import グラフから辿れない。明示的に entry として登録する
        "lib/lambda/**/index.ts",
        "test/**/*.test.ts",
        // vitest.config.ts の snapshotSerializers から文字列で参照されるため辿れない
        "test/snapshot-plugin.ts"
      ],
      "project": ["**/*.ts"],
      // tsx: cdk.json の "app": "npx tsx bin/app.ts" で CDK アプリ実行に使用（コードからは import しない）
      // esbuild: NodejsFunction のバンドルで aws-cdk-lib が内部起動する（コードからは import しない）
      "ignoreDependencies": ["tsx", "esbuild"]
    },
    "app": {
      "entry": ["main.ts", "test/**/*.test.ts"],
      "project": ["**/*.ts"]
    }
  }
}
